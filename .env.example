# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here        # used for text-embedding-3-small
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=docuchat               # must be dimension=1536 for text-embedding-3-small

# ── Optional but recommended ──────────────────────────────
ALLOWED_ORIGINS=https://yourapp.lovable.app,https://yourdomain.com
                                           # comma-separated; defaults to * (open) if not set

# ── For Supabase (when you wire up projects persistence) ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_key
